# AWS RDS PostgreSQL Connection
DB_HOST=quickcart-db.xxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=quickcart
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT Security
# NOTE: This must be a base64-encoded string of your secret key (e.g., 32 bytes -> 44 base64 characters)
# Example: Generate with: openssl rand -base64 32
JWT_SECRET=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=

# AI Provider Keys
GROQ_API_KEY=your_groq_key
NVIDIA_API_KEY=your_nvidia_key
GEMINI_API_KEY=your_gemini_key